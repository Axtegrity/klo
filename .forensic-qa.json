{
  "name": "KLO App",
  "url": "https://keithlodom.ai",
  "threshold": 80,
  "screenshotOnFail": true,

  "pages": [
    { "path": "/", "label": "Homepage", "critical": true },
    { "path": "/about", "label": "About" },
    { "path": "/assessments", "label": "Assessments", "critical": true },
    { "path": "/booking", "label": "Booking" },
    { "path": "/auth/signin", "label": "Sign In", "critical": true },
    { "path": "/events", "label": "Events" },
    { "path": "/feed", "label": "Feed" },
    { "path": "/pricing", "label": "Pricing" },
    { "path": "/vault", "label": "Vault" },
    { "path": "/support", "label": "Support" },
    { "path": "/conference", "label": "Conference" }
  ],

  "apiEndpoints": [
    { "path": "/api/events", "method": "GET", "expectedStatus": 200 },
    { "path": "/api/contact", "method": "POST", "expectedStatus": [200, 400, 405, 500] },
    { "path": "/api/assessments", "method": "GET", "expectedStatus": [200, 401] }
  ],

  "userFlows": [
    {
      "name": "Assessments Page Loads",
      "critical": true,
      "steps": [
        { "action": "goto", "path": "/assessments" },
        { "action": "waitForSelector", "selector": "h1, h2, [class*='assessment'], [class*='card']", "timeout": 5000 },
        { "action": "assertUrl", "pattern": "/assessments" }
      ]
    },
    {
      "name": "Sign In Page Loads",
      "steps": [
        { "action": "goto", "path": "/auth/signin" },
        { "action": "waitForSelector", "selector": "input[type='email'], input[name='email']", "timeout": 5000 },
        { "action": "assertVisible", "selector": "input[type='email'], input[name='email']" }
      ]
    },
    {
      "name": "Admin Login Succeeds",
      "critical": true,
      "requiresAuth": true,
      "steps": [
        { "action": "goto", "path": "/auth/signin" },
        { "action": "fill", "selector": "input[type='email'], input[name='email']", "value": "ENV:ADMIN_QA_EMAIL" },
        { "action": "fill", "selector": "input[type='password'], input[name='password']", "value": "ENV:ADMIN_QA_PASSWORD" },
        { "action": "click", "selector": "button[type='submit']" },
        { "action": "waitForNavigation", "timeout": 8000 },
        { "action": "assertNotUrl", "pattern": "/auth/signin" }
      ]
    },
    {
      "name": "Admin CMS Loads",
      "critical": true,
      "requiresAuth": true,
      "steps": [
        { "action": "goto", "path": "/admin" },
        { "action": "waitForSelector", "selector": "[class*='admin'], [class*='creative'], h1, h2", "timeout": 8000 },
        { "action": "assertNotUrl", "pattern": "/auth/signin" }
      ]
    },
    {
      "name": "Admin Home CMS Sections Visible",
      "critical": true,
      "requiresAuth": true,
      "steps": [
        { "action": "goto", "path": "/admin" },
        { "action": "waitForSelector", "selector": "button, [role='button']", "timeout": 8000 },
        { "action": "assertVisible", "selector": "button, [role='button']" }
      ]
    },
    {
      "name": "Admin Edit Modal Opens",
      "critical": true,
      "requiresAuth": true,
      "steps": [
        { "action": "goto", "path": "/admin" },
        { "action": "waitForSelector", "selector": "button:has(svg), [aria-label*='edit'], [aria-label*='Edit']", "timeout": 8000 },
        { "action": "click", "selector": "button:has(svg):first-of-type" },
        { "action": "waitForSelector", "selector": "[role='dialog'], .modal, input, textarea", "timeout": 5000 },
        { "action": "assertVisible", "selector": "[role='dialog'], .modal, input, textarea" }
      ]
    },
    {
      "name": "Admin Upload Document Route Responds",
      "critical": true,
      "requiresAuth": true,
      "steps": [
        { "action": "apiCheck", "path": "/api/admin/documents/upload", "method": "GET", "expectedStatus": [401, 405] }
      ]
    }
  ],

  "auth": {
    "loginUrl": "/auth/signin",
    "credentials": {
      "email": "ENV:ADMIN_QA_EMAIL",
      "password": "ENV:ADMIN_QA_PASSWORD"
    },
    "successIndicator": "nav, [href*='/admin'], [href*='/profile'], main",
    "enabled": true
  },

  "consoleErrors": {
    "failOnError": true,
    "ignorePatterns": [
      "favicon.ico",
      "third-party",
      "gtag",
      "analytics",
      "hotjar",
      "chunk load failed",
      "supabase.co/realtime",
      "WebSocket connection"
    ]
  },

  "brokenLinks": {
    "crawlDepth": 1,
    "ignorePatterns": [
      "mailto:",
      "tel:",
      "javascript:",
      "#",
      "linkedin.com",
      "facebook.com",
      "twitter.com",
      "instagram.com"
    ],
    "timeout": 10000
  }
}
